{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "corepack": true,
      "env": {
        "APP_VARIANT": "development",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      },
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "corepack": true,
      "env": {
        "APP_VARIANT": "preview",
        "EAS_BUILD_DISABLE_EXPO_DOCTOR_STEP": "1",
        "MOBILE_VERSION_POLICY": "appVersion",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      },
      "channel": "preview",
      "environment": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview:dev": {
      "corepack": true,
      "env": {
        "APP_VARIANT": "preview",
        "MOBILE_VERSION_POLICY": "fingerprint",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      },
      "channel": "preview",
      "environment": "preview",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "corepack": true,
      "env": {
        "APP_VARIANT": "production",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      },
      "channel": "production",
      "environment": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6787819824"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
